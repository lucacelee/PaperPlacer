{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"option": "watch",
			"problemMatcher": [
				"$tsc-watch"
			],
			"label": "tsc: watch - tsconfig.json"
		},
		{
			"type": "shell",
			"command": "npx cpx \"src/templates/**/*\" dist/templates --watch",
			"label": "copy html: watch"
		},
		{
			"dependsOn": [
				"tsc: watch - tsconfig.json",
				"copy html: watch"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "development: watch"
		}
	]
}